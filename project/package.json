{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint \"resources/js/**/*.{ts,tsx}\" \"tests/e2e/**/*.ts\" \"playwright.config.ts\" --ignore-pattern \"resources/js/compat/**\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"resources/js/**/*.{ts,tsx,scss}\" \"**/*.{md,json,yml,yaml}\"",
    "check:clean": "node scripts/cleanliness-check.mjs",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,scss,css}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@inertiajs/react": "^1.2.0",
    "@laravel/echo-react": "^2.3.1",
    "@marsidev/react-turnstile": "^1.4.2",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.3.3",
    "axios": "^1.7.7",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "laravel-echo": "^2.3.1",
    "laravel-vite-plugin": "^1.0.5",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "pusher-js": "^8.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-toastify": "^10.0.6",
    "sass": "1.69.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-bootstrap": "^2.10.5",
    "react-countup": "^6.5.3",
    "react-i18next": "^16.6.6",
    "simplebar": "^6.3.2",
    "simplebar-react": "^3.3.2",
    "swiper": "^12.1.3",
    "ziggy-js": "^2.4.2"
  }
}
